# Short Editor environment variables
#
# Copy this file to `.env.local` for local development, or set per environment
# (.env.development / .env.staging / .env.production) as needed.
# All NEXT_PUBLIC_* values are inlined into the client bundle at build time.

# Comma-separated list of CMS origins allowed to talk to the editor via postMessage.
# Required for embed mode to work in production. When empty in production,
# inbound postMessage events are silently dropped (fail-secure).
# Example (staging):
#   NEXT_PUBLIC_ALLOWED_CMS_ORIGINS=https://cms.stg.tigmedia.jp
# Example (multiple):
#   NEXT_PUBLIC_ALLOWED_CMS_ORIGINS=https://cms.tigmedia.jp,https://cms.demo.tigmedia.jp
NEXT_PUBLIC_ALLOWED_CMS_ORIGINS=
